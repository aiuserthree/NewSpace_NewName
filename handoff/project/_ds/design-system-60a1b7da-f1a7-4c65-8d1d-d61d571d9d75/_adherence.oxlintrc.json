{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/display/**",
              "components/feedback/**",
              "components/forms/**",
              "components/media/**",
              "components/navigation/**",
              "components/patterns/**",
              "ui_kits/contest/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Pretendard Variable|Gowun Batang))/i]",
        "message": "Font not provided by the design system. Available: Pretendard Variable, Gowun Batang."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|icon|children|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: variant, size, icon, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|fullWidth|disabled|loading|iconLeft|iconRight|href|type|children|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, fullWidth, disabled, loading, iconLeft, iconRight, href, type, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|padding|interactive|as|children|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, padding, interactive, as, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|strokeWidth|label|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, strokeWidth, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='ImageFrame'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|ratio|radius|label|sublabel|scrim|caption|objectPosition|children|key|ref|className|style|children)$/]",
        "message": "<ImageFrame> doesn't accept that prop. Declared props: src, alt, ratio, radius, label, sublabel, scrim, caption, objectPosition, children."
      },
      {
        "selector": "JSXOpeningElement[name.name='Notice'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|title|children|icon|action|onClose|key|ref|className|style|children)$/]",
        "message": "<Notice> doesn't accept that prop. Declared props: variant, title, children, icon, action, onClose."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProgressStep'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<ProgressStep> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeader'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|description|numeral|align|size|as|key|ref|className|style|children)$/]",
        "message": "<SectionHeader> doesn't accept that prop. Declared props: eyebrow, title, description, numeral, align, size, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpaceCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:numeral|name|kind|description|src|imageLabel|imageSublabel|ratio|requiredValue|optionalValue|onFieldChange|requiredPlaceholder|optionalPlaceholder|requiredError|showOptional|readOnly|key|ref|className|style|children)$/]",
        "message": "<SpaceCard> doesn't accept that prop. Declared props: numeral, name, kind, description, src, imageLabel, imageSublabel, ratio, requiredValue, optionalValue, onFieldChange, requiredPlaceholder, optionalPlaceholder, requiredError, showOptional, readOnly."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|required|optional|hint|error|prefix|readOnly|disabled|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: label, required, optional, hint, error, prefix, readOnly, disabled."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
