{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "",
  "installCommand": "",
  "outputDirectory": "handoff/project",
  "rewrites": [
    { "source": "/", "destination": "/01-intro.html" }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
